# ─────────────────────────────────────────────────────────────────────────────
# XQube Studio Web — Environment Variables Template
# Copy this file to .env.local and fill in every value before running locally.
# On Vercel: add each variable under Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────────────────────
#
# MUST use the Supabase TRANSACTION pooler (port 6543) — NOT the session pooler
# (port 5432). Session mode hits a 15-connection cap on serverless and causes:
#   EMAXCONNSESSION: max clients reached in session mode
#
# Where to find it:
#   Supabase Dashboard → Project → Connect → Connection string → Transaction
#
# Format:
#   postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
#
DATABASE_URI=postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true


# ── Payload CMS ───────────────────────────────────────────────────────────────
#
# Secret key used by Payload to sign JWTs and encrypt sensitive data.
# Must be at least 32 characters. Generate one with:
#   openssl rand -base64 32
#
PAYLOAD_SECRET=REPLACE_WITH_32_CHAR_RANDOM_SECRET


# ── Site URL ──────────────────────────────────────────────────────────────────
#
# The canonical public URL of the site (no trailing slash).
# Used in sitemap, OG tags, and structured data.
# Local dev: http://localhost:3000
# Production: https://www.xqubestudio.com
#
NEXT_PUBLIC_SITE_URL=https://www.xqubestudio.com


# ── Email (Resend) ────────────────────────────────────────────────────────────
#
# API key for sending transactional emails via Resend (contact form, etc.)
# Get it from: https://resend.com/api-keys
#
RESEND_API_KEY=re_REPLACE_WITH_YOUR_RESEND_API_KEY


# ── Contact Email ─────────────────────────────────────────────────────────────
#
# The inbox that receives contact form submissions.
#
CONTACT_EMAIL=info@xqubestudio.com


# ── Google Analytics (optional) ───────────────────────────────────────────────
#
# Google Analytics 4 Measurement ID.
# Leave empty to disable analytics.
# Format: G-XXXXXXXXXX
#
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
